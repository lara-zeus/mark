{
    "name": "lara-zeus/mark",
    "description": "Ready to use application marks feature.",
    "keywords": [
        "lara-zeus",
        "laravel",
        "mark"
    ],
    "homepage": "https://github.com/lara-zeus/mark",
    "support": {
        "issues": "https://github.com/lara-zeus/mark/issues",
        "source": "https://github.com/lara-zeus/mark"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulmajeed-Jamaan",
            "email": "abdulmajeed.jamaan@outlook.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.2",
        "illuminate/database": "^11.40|^12.0",
        "spatie/laravel-package-tools": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "LaraZeus\\Mark\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
        }
    },
    "scripts": {
        "post-install-cmd": [
            "composer --working-dir=demo install",
            "@setup"
        ],
        "setup": [
            "composer --working-dir=demo setup"
        ],
        "dev": [
            "composer --working-dir=demo dev"
        ],
        "analyse": [
            "composer --working-dir=demo analyse"
        ],
        "format": [
            "composer --working-dir=demo format"
        ],
        "test": [
            "composer --working-dir=demo test"
        ],
        "lint": [
            "composer --working-dir=demo lint"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraZeus\\Mark\\MarkServiceProvider"
            ],
            "aliases": {
                "Mark": "LaraZeus\\Mark\\Facades\\Mark"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
